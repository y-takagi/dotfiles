#!/usr/bin/env bash
set -e

current_path=`pwd`
repo_path=$(cd $(dirname $0);pwd)

# Setup dotfiles
mkdir -p $HOME/.config/git
ln -sf $repo_path/src/ignore $HOME/.config/git/

mkdir -p $HOME/.config/zed
ln -sf $repo_path/src/config/zed/settings.json $HOME/.config/zed/settings.json
ln -sf $repo_path/src/config/zed/keymap.json $HOME/.config/zed/keymap.json

for f in $repo_path/src/.[^.]* ; do
    ln -sf $f $HOME/
done
