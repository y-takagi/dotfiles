[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-/": "editor::Undo",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-z /": "editor::Redo",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-z p": "pane::GoBack",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-z .": "editor::GoToDefinition",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-z n": "pane::GoForward",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-z x": "command_palette::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-z f": "file_finder::Toggle",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-z g": "pane::DeploySearch",
    },
  },
